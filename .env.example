# Dhan API (Indian NFO pipeline — src/nfo)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
DHAN_BASE_URL=https://api.dhan.co/v2

# Parallel.ai (web intelligence — events, macro brief, flow, news)
# Get a key at https://platform.parallel.ai. Never commit the real key.
PARALLEL_API_KEY=get_from_https://platform.parallel.ai
# Set to 1 to force cache-only mode (no network calls).
PARALLEL_OFFLINE=0

# Massive.com API (legacy US pipeline — src/csp)
MASSIVE_API_KEY=your_key_here
MASSIVE_BASE_URL=https://api.massive.com
